# Tenda Monitor configuration
ROUTER_HOST=192.168.0.1
ROUTER_PASSWORD=
DB_PATH=./tenda.db
POLL_INTERVAL_MS=10000
WEB_PORT=3030
IPC_SOCKET=/tmp/tenda-monitor.sock
LOG_LEVEL=info
# Syslog UDP port. Default 5140 since 514 needs root. Forward 514→5140 with pf.
SYSLOG_PORT=5140
# Optional protected dashboard password. Set from Settings; stored as scrypt hash.
TENDA_PANEL_PASSWORD_HASH=
TENDA_PANEL_SESSION_SECRET=
# If TENDA_PANEL_PASSWORD_HASH is empty, first remote login uses default password: tvtv2tvtv2.
