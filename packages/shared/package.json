{
  "name": "@tenda/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./db": {
      "types": "./dist/db.d.ts",
      "default": "./dist/db.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./oui": {
      "types": "./dist/oui.d.ts",
      "default": "./dist/oui.js"
    },
    "./time": {
      "types": "./dist/time.d.ts",
      "default": "./dist/time.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && cp -R src/migrations dist/migrations",
    "dev": "tsc -p tsconfig.json --watch",
    "migrate": "node dist/migrate.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3"
  }
}
